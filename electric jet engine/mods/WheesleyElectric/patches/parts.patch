
:parts {

    #engine_*_wheesley {
        * > Module_Engine > Data_Engine {
            * > engine_mode {
                * > propellant {
                    mixtureName: "ElectricPropellant";
                }
            }
        }

        // Remove the internal methane/fuel resource container so the part
        // no longer shows a pointless empty fuel tank in the resource panel.
        * > resourceContainers > .MethaneAir  { @delete; }
        * > resourceContainers > .Methane     { @delete; }
        * > resourceContainers > .LiquidFuel  { @delete; }

    }

}

